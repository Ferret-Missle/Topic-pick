rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /topics/{topicId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    
      // Usage subcollection (per-user usage records)
      match /usage/{docId} {
        // Allow the authenticated user to read/write their own usage records
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /usage/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}